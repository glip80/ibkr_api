# Copy this file to .env and fill in your values.
# docker-compose picks up .env automatically.

# ── IBKR Connection ──────────────────────────────────────────────────────────
IBKR_HOST=127.0.0.1        # Use host.docker.internal when running in Docker
IBKR_PORT=7497             # 7497 = TWS paper, 7496 = TWS live, 4001 = Gateway
IBKR_CLIENT_ID=1
IBKR_TIMEOUT=30

# ── Cache TTLs ───────────────────────────────────────────────────────────────
QUOTES_TTL_HOURS=1
FUNDAMENTALS_TTL_HOURS=24

# ── Background Sync ──────────────────────────────────────────────────────────
SYNC_WATCHLIST=AAPL,MSFT,NVDA,GOOGL,AMZN
SYNC_INTERVAL_SECONDS=3600

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=text            # text | json

# ── MCP ──────────────────────────────────────────────────────────────────────
MCP_SERVER_NAME=ibkr-mcp

# ── Notes ────────────────────────────────────────────────────────────────────
# ib_async package: pip install ib_async  (PyPI: https://pypi.org/project/ib_async/)
# TWS port 7497 = paper trading (safe for testing)
# TWS port 7496 = live trading  (real money - be careful)
# IB Gateway port 4001 = Gateway (stable, lower resource usage than TWS)
# Set IBKR_CLIENT_ID to a unique number per simultaneous connection
