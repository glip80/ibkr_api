# Copy this file to .env and fill in your values.
# docker-compose picks up .env automatically.

# ── IBKR Connection ──────────────────────────────────────────────────────────
IBKR_HOST=127.0.0.1        # Use host.docker.internal when running in Docker
IBKR_PORT=4002             # 4002 = Gateway (paper) via Docker mapping 4002:4004
IBKR_CLIENT_ID=1
IBKR_TIMEOUT=30

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ibkr:password@localhost:5432/ibkr_mcp

# ── Background Sync ─────────────────────────────────────────────────────────
SYNC_INTERVAL_SECONDS=300
SYNC_LOOKBACK_DAYS=365

# ── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console         # console | json


TWS_USERID=alexpo941
TWS_PASSWORD=
TWS_PASSWORD_FILE=/run/secrets/tws_password

TWS_USERID_PAPER=alexpo9411
TWS_PASSWORD_PAPER=
TWS_PASSWORD_PAPER_FILE=/run/secrets/tws_password_paper
# ib-gateway
#TWS_SETTINGS_PATH=/home/ibgateway/Jts
# tws
#TWS_SETTINGS_PATH=/config/tws_settings
TWS_SETTINGS_PATH=
TWS_ACCEPT_INCOMING=yes
TRADING_MODE=paper
READ_ONLY_API=no
VNC_SERVER_PASSWORD=myVncPassword
TWOFA_TIMEOUT_ACTION=restart
BYPASS_WARNING=yes
AUTO_RESTART_TIME=11:59 PM
AUTO_LOGOFF_TIME=
TWS_COLD_RESTART=
SAVE_TWS_SETTINGS=08:00
RELOGIN_AFTER_2FA_TIMEOUT=yes
TIME_ZONE=Asia/Jerusalem
#Europe/Zurich
CUSTOM_CONFIG=
SSH_TUNNEL=
SSH_OPTIONS=
SSH_ALIVE_INTERVAL=
SSH_ALIVE_COUNT=
SSH_PASSPHRASE=
SSH_REMOTE_PORT=
SSH_USER_TUNNEL=
SSH_RESTART=
SSH_VNC_PORT=